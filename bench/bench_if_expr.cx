// perf-rider: INTERPRETER-ONLY — if-as-expression (#046) in a hot loop.
// If-expr does not lower yet (the #046 SKIP class); measured on one backend,
// still regression-tracked. Becomes two-backend when D1.4 lands.
acc: t64 = 0
i: t64 = 0
while (i < 700000) {
    v: t64 = if i % 2 == 0 { i % 5 } else { i % 3 }
    acc = acc + v
    i += 1
}
print(acc)
