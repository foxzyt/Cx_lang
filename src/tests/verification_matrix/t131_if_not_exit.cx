// CX-97: exit-code-based JIT parity — Branch terminator with negated condition.
// No stdout; correctness verified by exit code only (0 = all asserts held).
y: t64 = 5

result: t64 = 0
if !(y == 5) {
    result = 99
} else {
    result = 1
}
assert_eq(result, 1)

result = 0
if !(y > 10) {
    result = 2
} else {
    result = 0
}
assert_eq(result, 2)
