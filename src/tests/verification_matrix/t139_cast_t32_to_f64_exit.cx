// CX-103: exit-code-based JIT parity — implicit t32→f64 cast and round-trip.
// Assigns a t32 value to an f64 variable (implicit widening cast), then
// reads it back into t32 (implicit truncating cast) and asserts equality.
a: t32 = 42
b: f64 = a
c: t32 = b
assert_eq(c, 42)

x: t32 = 100
y: f64 = x
z: t32 = y
assert_eq(z, 100)
