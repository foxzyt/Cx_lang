// Pattern matching, guards — discriminating canary: a guard must only
// evaluate after its own arm's pattern already matched. The first arm's
// pattern (Red) does NOT match the scrutinee (Green), and its guard would
// trip a DivByZero if it were ever evaluated. If guards were implemented as
// "evaluate everything, pick the first fully-passing arm" this would abort
// with a divide-by-zero error instead of printing 1.
enum Color { Red, Green, Blue }

zero: t32 = 0

let c;
c = Color::Green

when c {
    Color::Red if (5 / zero == 1) => print(999),
    Color::Green => print(1),
    _ => print(0),
}
