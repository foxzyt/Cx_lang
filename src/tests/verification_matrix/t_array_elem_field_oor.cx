// CR#2: an array element in a struct field must range-check at the declared width.
// `items: [3: t8]` makes each element a t8, so 300 (out of -128..127) is rejected.
// Before CR#2 the element-type hint never reached the struct-field path.
struct B { items: [3: t8] }
b: B = B { items: [1, 2, 300] }
print(b.items:[0])
