// CX-117/CX-209: exit-code-based JIT parity — negative t32→f64 widening cast.
// Verifies sign preservation when a negative t32 value widens to f64,
// then narrows back to t32 for assert_eq verification.
a: t32 = -42
b: f64 = a
c: t32 = b
assert_eq(c, -42)

x: t32 = -100
y: f64 = x
z: t32 = y
assert_eq(z, -100)
