fnc: t64 sum_up_to(limit: t64) {
    total: t64 = 0
    i: t64 = 0
    while (i < limit) {
        total = total + i
        i = i + 1
    }
    return total
}

fnc: t64 abs_diff(a: t64, b: t64) {
    if a > b {
        return a - b
    }
    return b - a
}

print(sum_up_to(5))
print(abs_diff(10, 3))
print(abs_diff(3, 10))
