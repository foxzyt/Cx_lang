// Gate-2a: read back the NEGATIVE element of a struct fixed-size array field.
// This is the exact bug case from t_array_elem_field_in_range, but reading
// index 0 (the -128) instead of index 2 (127) — proving the negative store
// produces the correct sign-preserved value, not just "no crash". The element
// is narrowed to i8 before the store (1-byte, no overrun); the read sign-
// extends. Interpreter and JIT both print -128.
struct B { items: [3: t8] }
b: B = B { items: [-128, 0, 127] }
print(b.items:[0])
