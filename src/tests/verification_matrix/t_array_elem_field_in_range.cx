// CR#2: in-range and boundary array elements in a struct field pass (-128 and 127
// are the t8 limits). The interpreter is the reference and prints 127 (index 2).
//
// Gate-2a closed the codegen bug this fixture exposed: the Cranelift backend
// stored each element at the value's width (i64) instead of the element width,
// overrunning the array and corrupting the stack when an element was NEGATIVE
// (0xFF high bytes). Elements are now narrowed to the element type before the
// store — both backends print 127, and the negative element reads back correctly
// (see t_struct_array_neg_read for the -128 read).
struct B { items: [3: t8] }
b: B = B { items: [-128, 0, 127] }
print(b.items:[2])
